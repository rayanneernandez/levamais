        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["network_id", "client_id", "subject", "description"],
                "properties": {
                  "network_id": { "type": "string", "format": "uuid" },
                  "client_id": { "type": "string", "format": "uuid" },
                  "subject": { "type": "string", "example": "Problema com pontos" },
                  "description": { "type": "string", "example": "Descrição detalhada do problema" },
                  "category": { "type": "string", "example": "pontos" },
                  "priority": { "type": "string", "enum": ["low", "medium", "high"], "example": "medium" },
                  "status": { "type": "string", "example": "open" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Ticket criado" }
        }
      },
      "get": {
        "summary": "Buscar Tickets do Cliente",
