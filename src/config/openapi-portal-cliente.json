          { "name": "ticket_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{ticket_id}" },
          { "name": "order", "in": "query", "schema": { "type": "string" }, "example": "created_at.asc" }
        ],
        "responses": {
          "200": { "description": "Lista de mensagens" }
        }
      }
