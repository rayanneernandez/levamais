{
  "openapi": "3.0.3",
  "info": {
    "title": "Leva+ Portal do Cliente - API",
    "description": "API completa para replicar o Portal do Cliente Leva+ em aplicativos nativos. Inclui autenticação, perfil, transações, notificações, Leva+ One, retenção, indicação e suporte.",
    "version": "2.0.0",
    "contact": {
      "name": "Suporte Leva+",
      "email": "comercial@levamais.app"
    }
  },
  "servers": [
    {
      "url": "https://auivszkscfcpczrkecoc.supabase.co",
      "description": "Servidor de Produção"
    }
  ],
  "security": [
    {
      "bearerAuth": [],
      "apiKey": []
    }
  ],
  "paths": {
    "/functions/v1/send-client-login-code": {
      "post": {
        "summary": "Solicitar Código de Login",
        "description": "Envia um código de verificação por email para o cliente. Primeira etapa do login OTP.",
        "tags": ["1. Autenticação"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cpf", "email"],
                "properties": {
                  "cpf": {
                    "type": "string",
                    "description": "CPF do cliente (apenas números)",
                    "example": "12345678900"
                  },
                  "email": {
                    "type": "string",
                    "description": "Email cadastrado do cliente",
                    "example": "cliente@email.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Código enviado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Código enviado para o email" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/functions/v1/verify-client-login-code": {
      "post": {
        "summary": "Verificar Código e Obter Sessão",
        "description": "Verifica o código OTP e retorna token JWT + dados do cliente. Segunda etapa do login.",
        "tags": ["1. Autenticação"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cpf", "email", "code"],
                "properties": {
                  "cpf": { "type": "string", "example": "12345678900" },
                  "email": { "type": "string", "example": "cliente@email.com" },
                  "code": { "type": "string", "description": "Código de 6 dígitos recebido por email", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "client": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "cpf": { "type": "string", "example": "12345678900" },
                        "full_name": { "type": "string", "example": "Nome do Cliente" },
                        "email": { "type": "string", "example": "cliente@email.com" },
                        "phone": { "type": "string", "example": "11999999999" },
                        "birth_date": { "type": "string", "example": "1990-01-15" },
                        "is_one_member": { "type": "boolean", "example": false },
                        "favorite_network_id": { "type": "string", "format": "uuid" }
                      }
                    },
                    "session_token": { "type": "string", "description": "JWT para usar nas próximas requisições" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/functions/v1/client-first-registration": {
      "post": {
        "summary": "Primeiro Cadastro",
        "description": "Registra um novo cliente na plataforma.",
        "tags": ["1. Autenticação"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cpf", "email", "full_name", "phone", "password", "network_id"],
                "properties": {
                  "cpf": { "type": "string", "example": "12345678900" },
                  "email": { "type": "string", "example": "cliente@email.com" },
                  "full_name": { "type": "string", "example": "Nome Completo" },
                  "phone": { "type": "string", "example": "11999999999" },
                  "birth_date": { "type": "string", "example": "1990-01-15" },
                  "password": { "type": "string", "example": "senha123" },
                  "network_id": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cadastro realizado com sucesso"
          }
        }
      }
    },
    "/functions/v1/client-forgot-password": {
      "post": {
        "summary": "Recuperar Senha",
        "description": "Envia link de recuperação de senha por email.",
        "tags": ["1. Autenticação"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cpf", "email"],
                "properties": {
                  "cpf": { "type": "string", "example": "12345678900" },
                  "email": { "type": "string", "example": "cliente@email.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Email de recuperação enviado" }
        }
      }
    },
    "/rest/v1/clients": {
      "get": {
        "summary": "Buscar Perfil do Cliente",
        "description": "Retorna dados completos do perfil do cliente. Use filtro `?cpf=eq.{cpf}` ou `?id=eq.{id}`.",
        "tags": ["2. Dados do Cliente"],
        "parameters": [
          { "name": "cpf", "in": "query", "schema": { "type": "string" }, "description": "Filtro por CPF: eq.12345678900" },
          { "name": "id", "in": "query", "schema": { "type": "string" }, "description": "Filtro por ID: eq.{uuid}" },
          { "name": "select", "in": "query", "schema": { "type": "string" }, "description": "Campos a retornar", "example": "id,full_name,email,phone,total_points,is_one_member" }
        ],
        "responses": {
          "200": {
            "description": "Dados do cliente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Client"
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Atualizar Perfil do Cliente",
        "description": "Atualiza dados do perfil. Filtrar com `?id=eq.{client_id}`. Também usado para: definir rede favorita, ativar/desativar resgate automático, marcar tutorial.",
        "tags": ["2. Dados do Cliente"],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{client_id}" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "full_name": { "type": "string", "example": "Novo Nome" },
                  "phone": { "type": "string", "example": "11988888888" },
                  "address_street": { "type": "string" },
                  "address_number": { "type": "string" },
                  "address_complement": { "type": "string" },
                  "address_neighborhood": { "type": "string" },
                  "address_city": { "type": "string" },
                  "address_state": { "type": "string" },
                  "address_zip": { "type": "string" },
                  "favorite_network_id": { "type": "string", "format": "uuid", "description": "Define rede favorita" },
                  "auto_redemption_enabled": { "type": "boolean", "description": "Ativa/desativa resgate automático (sem PIN)" },
                  "auto_redemption_disable_mode": { "type": "string", "enum": ["immediate", "scheduled"], "description": "Modo de desligamento: 'immediate' = desliga após cada resgate, 'scheduled' = desliga após período" },
                  "auto_redemption_disable_scheduled_at": { "type": "string", "format": "date-time", "description": "Data/hora para desligar automaticamente (usado quando disable_mode='scheduled')" },
                  "tutorial_completed": { "type": "boolean", "description": "Marca tutorial como concluído" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Atualizado com sucesso" }
        }
      }
    },
    "/rest/v1/loyalty_balances": {
      "get": {
        "summary": "Buscar Saldos (Pontos/Cashback)",
        "description": "Retorna saldos de fidelidade do cliente em todas as redes.",
        "tags": ["2. Dados do Cliente"],
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{client_id}" },
          { "name": "select", "in": "query", "schema": { "type": "string" }, "example": "*,networks(name,logo_url,loyalty_type)" }
        ],
        "responses": {
          "200": {
            "description": "Lista de saldos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "format": "uuid" },
                      "client_id": { "type": "string", "format": "uuid" },
                      "network_id": { "type": "string", "format": "uuid" },
                      "balance": { "type": "number", "example": 150.50 },
                      "loyalty_type": { "type": "string", "enum": ["cashback", "points"] },
                      "networks": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string", "example": "Posto ABC" },
                          "logo_url": { "type": "string" },
                          "loyalty_type": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/networks": {
      "get": {
        "summary": "Buscar Redes Disponíveis",
        "description": "Lista redes ativas. Filtrar com `?is_active=eq.true`. Inclui configurações de fidelidade, One, retenção e resgate.",
        "tags": ["3. Redes e Lojas"],
        "parameters": [
          { "name": "is_active", "in": "query", "schema": { "type": "string" }, "example": "eq.true" },
          { "name": "id", "in": "query", "schema": { "type": "string" }, "description": "eq.{network_id} para buscar rede específica" },
          { "name": "select", "in": "query", "schema": { "type": "string" }, "example": "id,name,logo_url,loyalty_type,primary_color,one_enabled,retention_enabled,retention_multiplier_6m,retention_multiplier_9m,retention_multiplier_12m,max_redemption_sale_percentage,referral_enabled,referral_bonus_type,referral_bonus_value,referral_bonus_referred_value" }
        ],
        "responses": {
          "200": {
            "description": "Lista de redes com configurações",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "format": "uuid" },
                      "name": { "type": "string", "example": "Posto ABC" },
                      "logo_url": { "type": "string" },
                      "loyalty_type": { "type": "string", "enum": ["cashback", "points"] },
                      "primary_color": { "type": "string", "example": "#FF6600" },
                      "one_enabled": { "type": "boolean", "description": "Se true, mostrar propaganda/funcionalidades do Leva+ One. Se false, ocultar tudo do One." },
                      "retention_enabled": { "type": "boolean", "description": "Se true, mostrar Programa de Benefícios (retenção) no portal." },
                      "retention_multiplier_6m": { "type": "number", "example": 1.1, "description": "Multiplicador bônus para compromisso de 6 meses (ex: 1.1 = +10%)" },
                      "retention_multiplier_9m": { "type": "number", "example": 1.15, "description": "Multiplicador bônus para compromisso de 9 meses (ex: 1.15 = +15%)" },
                      "retention_multiplier_12m": { "type": "number", "example": 1.2, "description": "Multiplicador bônus para compromisso de 12 meses (ex: 1.2 = +20%)" },
                      "max_redemption_sale_percentage": { "type": "integer", "description": "Percentual máximo de uma venda que pode ser pago com fidelidade (1-100). Null = 100%." }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/stores": {
      "get": {
        "summary": "Buscar Lojas de uma Rede",
        "description": "Lista lojas ativas de uma rede. Inclui coordenadas para mapa.",
        "tags": ["3. Redes e Lojas"],
        "parameters": [
          { "name": "network_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{network_id}" },
          { "name": "is_active", "in": "query", "schema": { "type": "string" }, "example": "eq.true" },
          { "name": "select", "in": "query", "schema": { "type": "string" }, "example": "id,name,address,city,state,phone,latitude,longitude,opening_hours,flag,services", "description": "Incluir flag e services para mostrar bandeira e serviços disponíveis" }
        ],
        "responses": {
          "200": {
            "description": "Lista de lojas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Store"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/transactions": {
      "get": {
        "summary": "Buscar Histórico de Transações",
        "description": "Retorna extrato de transações do cliente. Tipos: accumulation, redemption, adjustment, expiration, bonus. Suporta paginação com limit/offset e filtro por período.",
        "tags": ["4. Transações e Extrato"],
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{client_id}" },
          { "name": "status", "in": "query", "schema": { "type": "string" }, "description": "eq.completed" },
          { "name": "created_at", "in": "query", "schema": { "type": "string" }, "description": "gte.2024-01-01 ou lte.2024-12-31" },
          { "name": "order", "in": "query", "schema": { "type": "string" }, "example": "created_at.desc" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" }, "example": 50 },
          { "name": "offset", "in": "query", "schema": { "type": "integer" }, "example": 0 },
          { "name": "select", "in": "query", "schema": { "type": "string" }, "example": "*,stores(name)" }
        ],
        "responses": {
          "200": {
            "description": "Lista de transações",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transaction"
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Enviar Avaliação NPS",
        "description": "Atualiza uma transação com a avaliação NPS do cliente. Filtrar com `?id=eq.{transaction_id}`.",
        "tags": ["5. NPS (Avaliação)"],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{transaction_id}" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nps_rating": { "type": "integer", "minimum": 0, "maximum": 10, "example": 9 },
                  "nps_comment": { "type": "string", "example": "Ótimo atendimento!" },
                  "nps_rated_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Avaliação registrada" }
        }
      }
    },
    "/functions/v1/apply-nps-rating-reward": {
      "post": {
        "summary": "Aplicar Recompensa por Avaliação",
        "description": "Aplica bônus ao cliente após avaliação NPS (se configurado pela rede).",
        "tags": ["5. NPS (Avaliação)"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["transaction_id", "rating"],
                "properties": {
                  "transaction_id": { "type": "string", "format": "uuid" },
                  "rating": { "type": "integer", "example": 9 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Recompensa aplicada" }
        }
      }
    },
    "/rest/v1/client_notification_recipients": {
      "get": {
        "summary": "Buscar Notificações do Cliente",
        "description": "Retorna notificações enviadas ao cliente com título e mensagem.",
        "tags": ["6. Notificações"],
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{client_id}" },
          { "name": "select", "in": "query", "schema": { "type": "string" }, "example": "*,client_notifications(title,message,created_at)" },
          { "name": "order", "in": "query", "schema": { "type": "string" }, "example": "created_at.desc" }
        ],
        "responses": {
          "200": { "description": "Lista de notificações" }
        }
      },
      "patch": {
        "summary": "Marcar Notificação como Lida",
        "description": "Marca uma notificação como lida. Filtrar com `?id=eq.{recipient_id}`.",
        "tags": ["6. Notificações"],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{recipient_id}" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "is_read": { "type": "boolean", "example": true },
                  "read_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Marcada como lida" }
        }
      }
    },
    "/rest/v1/push_subscriptions": {
      "post": {
        "summary": "Registrar Push Token",
        "description": "Registra o dispositivo para receber notificações push.",
        "tags": ["6. Notificações"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "network_id", "endpoint", "p256dh", "auth"],
                "properties": {
                  "client_id": { "type": "string", "format": "uuid" },
                  "network_id": { "type": "string", "format": "uuid" },
                  "endpoint": { "type": "string", "example": "https://fcm.googleapis.com/..." },
                  "p256dh": { "type": "string" },
                  "auth": { "type": "string" },
                  "device_info": {
                    "type": "object",
                    "properties": {
                      "platform": { "type": "string", "example": "android" },
                      "model": { "type": "string", "example": "Pixel 7" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Token registrado" }
        }
      }
    },
    "/rest/v1/leva_one_config": {
      "get": {
        "summary": "Configuração do Leva+ One na Rede",
        "description": "Verifica se a rede tem Leva+ One ativo e retorna configurações.",
        "tags": ["7. Leva+ One"],
        "parameters": [
          { "name": "network_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{network_id}" },
          { "name": "is_active", "in": "query", "schema": { "type": "string" }, "example": "eq.true" }
        ],
        "responses": {
          "200": {
            "description": "Configuração do Leva+ One",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "network_id": { "type": "string", "format": "uuid" },
                    "is_active": { "type": "boolean" },
                    "monthly_value": { "type": "number", "example": 29.90 },
                    "minimum_period_months": { "type": "integer", "example": 3 },
                    "cashback_multiplier": { "type": "number", "example": 2.0 },
                    "points_multiplier": { "type": "number", "example": 2.0 },
                    "additional_benefits": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/client_subscriptions_one": {
      "get": {
        "summary": "Status de Assinatura do Cliente",
        "description": "Verifica se o cliente tem assinatura ativa do Leva+ One.",
        "tags": ["7. Leva+ One"],
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{client_id}" },
          { "name": "status", "in": "query", "schema": { "type": "string" }, "example": "eq.active" }
        ],
        "responses": {
          "200": { "description": "Dados da assinatura" }
        }
      }
    },
    "/functions/v1/create-one-credit-card-subscription": {
      "post": {
        "summary": "Criar Assinatura com Cartão",
        "description": "Cria uma assinatura Leva+ One com pagamento via cartão de crédito.",
        "tags": ["7. Leva+ One"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "network_id", "card", "holder_info"],
                "properties": {
                  "client_id": { "type": "string", "format": "uuid" },
                  "network_id": { "type": "string", "format": "uuid" },
                  "card": {
                    "type": "object",
                    "properties": {
                      "holder_name": { "type": "string", "example": "NOME NO CARTAO" },
                      "number": { "type": "string", "example": "4111111111111111" },
                      "expiry_month": { "type": "string", "example": "12" },
                      "expiry_year": { "type": "string", "example": "2025" },
                      "cvv": { "type": "string", "example": "123" }
                    }
                  },
                  "holder_info": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "email": { "type": "string" },
                      "cpf": { "type": "string" },
                      "phone": { "type": "string" },
                      "postal_code": { "type": "string" },
                      "address_number": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Assinatura criada" }
        }
      }
    },
    "/functions/v1/update-one-subscription-card": {
      "post": {
        "summary": "Atualizar Cartão da Assinatura",
        "description": "Atualiza o cartão de crédito de uma assinatura ativa.",
        "tags": ["7. Leva+ One"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subscription_id", "card"],
                "properties": {
                  "subscription_id": { "type": "string", "format": "uuid" },
                  "card": {
