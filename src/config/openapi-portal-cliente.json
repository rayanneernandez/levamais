                  }
                }
              }
            }
          }
        }
      }
    },
    "/functions/v1/client-portal-config": {
      "post": {
        "summary": "Config Completa do Portal (Endpoint Agregado)",
        "description": "Retorna TODOS os dados necessários para o app em uma única chamada: perfil do cliente, config da rede (One, retenção, resgate), saldos, notificações e compromisso ativo. Ideal para carregar a home do app.",
        "tags": ["12. Endpoint Agregado"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id"],
                "properties": {
                  "client_id": { "type": "string", "format": "uuid", "description": "ID do cliente logado" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dados completos do portal",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "client": { "$ref": "#/components/schemas/Client" },
                    "favorite_network_config": {
                      "type": "object",
                      "nullable": true,
                      "description": "Configurações da rede favorita do cliente",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "name": { "type": "string" },
                        "logo_url": { "type": "string" },
                        "loyalty_type": { "type": "string", "enum": ["cashback", "points"] },
                        "one_enabled": { "type": "boolean", "description": "Se false, NÃO mostrar propaganda/cards do Leva+ One" },
                        "retention_enabled": { "type": "boolean", "description": "Se true, mostrar Programa de Benefícios" },
                        "retention_multiplier_6m": { "type": "number" },
                        "retention_multiplier_9m": { "type": "number" },
                        "retention_multiplier_12m": { "type": "number" },
                        "max_redemption_sale_percentage": { "type": "integer" },
                        "referral_enabled": { "type": "boolean" },
                        "referral_bonus_type": { "type": "string" },
                        "referral_bonus_value": { "type": "number" },
                        "referral_bonus_referred_value": { "type": "number" }
                      }
                    },
                    "retention_commitment": {
                      "type": "object",
                      "nullable": true,
                      "description": "Compromisso de retenção ativo (ou null)",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "commitment_months": { "type": "integer" },
                        "multiplier_applied": { "type": "number" },
                        "status": { "type": "string" },
                        "expires_at": { "type": "string", "format": "date-time" }
                      }
                    },
                    "networks": {
                      "type": "array",
                      "description": "Todas as redes do cliente com saldos e lojas. A rede favorita vem primeiro (is_favorite=true).",
                      "items": {
                        "type": "object",
                        "properties": {
                          "network_id": { "type": "string", "format": "uuid" },
                          "balance": { "type": "number", "description": "Saldo de fidelidade nesta rede" },
                          "is_favorite": { "type": "boolean", "description": "true se for a rede principal do cliente" },
                          "network": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string" },
                              "name": { "type": "string" },
                              "logo_url": { "type": "string" },
                              "loyalty_type": { "type": "string" },
                              "primary_color": { "type": "string" },
                              "one_enabled": { "type": "boolean" },
                              "retention_enabled": { "type": "boolean" },
                              "max_redemption_sale_percentage": { "type": "integer" }
                            }
                          },
                          "stores": {
                            "type": "array",
                            "description": "Lojas ativas desta rede com bandeira e serviços",
                            "items": { "$ref": "#/components/schemas/Store" }
                          }
                        }
                      }
                    },
                    "notifications": {
                      "type": "object",
                      "properties": {
                        "unread_count": { "type": "integer" },
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string" },
                              "is_read": { "type": "boolean" },
                              "client_notifications": {
                                "type": "object",
                                "properties": {
                                  "title": { "type": "string" },
                                  "message": { "type": "string" },
                                  "created_at": { "type": "string" }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtido via /functions/v1/verify-client-login-code"
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "apikey",
        "description": "Anon Key pública da API"
      }
    },
    "schemas": {
      "Client": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "cpf": { "type": "string", "example": "12345678900" },
          "full_name": { "type": "string", "example": "Nome do Cliente" },
          "email": { "type": "string", "example": "cliente@email.com" },
          "phone": { "type": "string", "example": "11999999999" },
          "birth_date": { "type": "string", "example": "1990-01-15" },
          "address_street": { "type": "string" },
          "address_number": { "type": "string" },
          "address_complement": { "type": "string" },
          "address_neighborhood": { "type": "string" },
          "address_city": { "type": "string" },
          "address_state": { "type": "string" },
          "address_zip": { "type": "string" },
          "is_one_member": { "type": "boolean" },
          "one_member_since": { "type": "string", "format": "date-time", "nullable": true },
          "favorite_network_id": { "type": "string", "format": "uuid" },
          "auto_redemption_enabled": { "type": "boolean", "description": "Se true, resgate sem PIN" },
          "auto_redemption_disable_mode": { "type": "string", "enum": ["immediate", "scheduled"], "description": "Modo de desligamento do resgate automático" },
          "auto_redemption_disable_scheduled_at": { "type": "string", "format": "date-time", "description": "Data agendada para desligar resgate" },
          "tutorial_completed": { "type": "boolean" },
          "total_points": { "type": "number" },
          "codigo": { "type": "string", "description": "Código de indicação do cliente" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "example": "Loja Centro" },
          "address": { "type": "string", "example": "Rua Principal, 100" },
          "city": { "type": "string", "example": "São Paulo" },
          "state": { "type": "string", "example": "SP" },
          "phone": { "type": "string", "example": "1133334444" },
          "latitude": { "type": "number", "example": -23.5505 },
          "longitude": { "type": "number", "example": -46.6333 },
          "opening_hours": { "type": "string", "example": "06:00 - 22:00" },
          "flag": { "type": "string", "nullable": true, "enum": ["ipiranga", "shell", "vibra", "ale", "branca", "none", null], "description": "Bandeira do posto. Valores: ipiranga, shell, vibra, ale, branca, none ou null" },
          "services": { "type": "array", "nullable": true, "items": { "type": "string", "enum": ["conveniencia", "totem_eletrico", "caixa_24h", "troca_oleo", "banheiro", "chuveiro", "estacionamento", "lava_jato"] }, "description": "Serviços disponíveis no posto/loja" }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "client_id": { "type": "string", "format": "uuid" },
          "store_id": { "type": "string", "format": "uuid" },
          "network_id": { "type": "string", "format": "uuid" },
          "type": { "type": "string", "enum": ["accumulation", "redemption", "adjustment", "expiration", "bonus"], "description": "Tipo da transação" },
          "amount": { "type": "number", "example": 100.00 },
          "points": { "type": "number", "example": 10.00 },
          "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "reversed"] },
          "created_at": { "type": "string", "format": "date-time" },
          "stores": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "example": "Loja Centro" }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "AUTH_ERROR" },
          "message": { "type": "string", "example": "Credenciais inválidas" }
        }
      }
    }
  },
  "tags": [
    { "name": "1. Autenticação", "description": "Login OTP, cadastro e recuperação de senha" },
    { "name": "2. Dados do Cliente", "description": "Perfil, saldos e configurações do cliente" },
    { "name": "3. Redes e Lojas", "description": "Redes disponíveis e lojas com localização" },
    { "name": "4. Transações e Extrato", "description": "Histórico de acúmulo, resgate e movimentações" },
    { "name": "5. NPS (Avaliação)", "description": "Avaliação de transações e recompensas" },
    { "name": "6. Notificações", "description": "Notificações e push tokens" },
    { "name": "7. Leva+ One", "description": "Assinatura premium, promoções e gestão" },
    { "name": "8. Programa de Retenção", "description": "Compromissos de fidelidade com multiplicadores" },
    { "name": "9. Programa de Indicação", "description": "Código de indicação e histórico" },
    { "name": "10. Suporte", "description": "Tickets e mensagens de suporte" },
    { "name": "11. Utilitários", "description": "CEP e outros utilitários" },
    { "name": "12. Endpoint Agregado", "description": "Endpoint único que retorna todos os dados necessários para o app" }
  ]
}
