        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "eq.{client_id}" },
          { "name": "order", "in": "query", "schema": { "type": "string" }, "example": "created_at.desc" }
        ],
        "responses": {
          "200": { "description": "Lista de tickets" }
        }
      }
    },
